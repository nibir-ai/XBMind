# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# XBMind Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy to .env and fill in values.
# These override config.yaml settings.

# ── LLM API Keys ─────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── TTS API Keys ─────────────────────────────────
ELEVENLABS_API_KEY=

# ── Google Cloud STT ──────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=

# ── Bluetooth ─────────────────────────────────────
XBMIND_BLUETOOTH__DEVICE_NAME=SRS-XB100
XBMIND_BLUETOOTH__DEVICE_MAC=

# ── LLM Provider Override ────────────────────────
XBMIND_LLM__PROVIDER=ollama
XBMIND_LLM__OLLAMA__MODEL=llama3.2
XBMIND_LLM__OLLAMA__BASE_URL=http://localhost:11434

# ── STT Provider Override ────────────────────────
XBMIND_STT__PROVIDER=faster_whisper

# ── TTS Provider Override ────────────────────────
XBMIND_TTS__PROVIDER=piper

# ── Logging ───────────────────────────────────────
XBMIND_LOGGING__LEVEL=info
XBMIND_LOGGING__FORMAT=console
